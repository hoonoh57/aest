"""
DataCollector — DB 캔들만 사용하여 RiskFilterAgent 입력 데이터 생성

- 일봉: stock_info.daily_candles (기존 DB)
- 분봉: aest_db.candle_minute (전일 14:00 ~ 당일 15:30)
- 30틱: aest_db.candle_tick30 (전일 14:00 ~ 당일 15:30)
- 지표: core.py의 compute_tick_intensity, compute_aest,
        compute_supertrend, compute_jma_trend
"""

import sys, os
from datetime import date, timedelta
from dataclasses import dataclass, field
from typing import Optional, List, Dict
import pandas as pd

sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
from aest_db import AestDB
from core import (
    compute_tick_intensity,
    compute_aest,
    compute_supertrend,
    compute_jma_trend,
)


@dataclass
class StockDayData:
    """RiskFilterAgent 에 전달할 종목-일 데이터"""
    # 기본 정보
    code: str = ""
    name: str = ""
    capture_date: date = None
    market_cap: float = 0.0        # 억 원

    # 전일 일봉
    prev_open: int = 0
    prev_high: int = 0
    prev_low: int = 0
    prev_close: int = 0
    prev_volume: int = 0

    # 당일
    today_open: int = 0
    price_0905: int = 0            # 09:05 시점 종가
    volume_5min: int = 0           # 09:00~09:05 누적 거래량
    amount_5min: float = 0.0       # 09:00~09:05 거래대금 (원)

    # 기본 지표
    gap_pct: float = 0.0           # 갭 (%)
    early_move_pct: float = 0.0    # 초반 등락 (%)
    upper_wick_ratio: float = 0.0  # 전일 윗꼬리 비율
    vol_ratio_5d: float = 0.0      # 당일/5일평균 거래량 비
    close_position: float = 0.0    # 전일 종가위치 (0~1)
    bearish_count: int = 0         # 최근 연속 음봉 수
    avg_volume_5d: float = 0.0     # 5일 평균 거래량

    # 틱강도 지표
    tick_intensity_avg: float = 0.0   # 09:00~09:05 평균 틱강도
    tick_ma5_last: float = 0.0        # 09:05 시점 틱강도 MA5
    tick_ma20_last: float = 0.0       # 09:05 시점 틱강도 MA20
    tick_bearish: bool = False         # MA5 < MA20 여부

    # AEST 지표
    aest_value: float = 0.0           # 09:05 시점 AEST 값
    aest_bullish: bool = False        # AEST > 0 여부

    # SuperTrend 지표
    st_direction: int = 0             # 1=상승, -1=하락, 0=미정
    st_value: float = 0.0            # SuperTrend 값

    # JMA 지표
    jma_value: float = 0.0           # 09:05 시점 JMA 값
    jma_trend: int = 0               # 1=상승, -1=하락, 0=미정


class DataCollector:
    def __init__(self, db: AestDB = None):
        self.db = db or AestDB()

    def _prev_business_day(self, d: date) -> date:
        prev = d - timedelta(days=1)
        while prev.weekday() >= 5:
            prev -= timedelta(days=1)
        return prev

    # ── timedelta → 문자열 변환 헬퍼 ──
    def _tm_to_str(self, tm) -> str:
        """timedelta / time / str → 'HH:MM:SS' 형식"""
        if isinstance(tm, timedelta):
            total = int(tm.total_seconds())
            h = total // 3600
            m = (total % 3600) // 60
            s = total % 60
            return f"{h:02d}:{m:02d}:{s:02d}"
        return str(tm)

    def _tm_hhmm(self, tm) -> str:
        """timedelta / time / str → 'HH:MM' 형식 (비교용)"""
        return self._tm_to_str(tm)[:5]

    def collect(self, code: str, capture_date: date) -> Optional[StockDayData]:
        """종목 코드와 포착일로부터 전체 분석 데이터를 수집·계산"""

        # ── 1. 종목 기본 정보 ──
        stock = self.db.get_stock_by_code(code)
        if not stock:
            print(f"    ⚠ 종목 정보 없음: {code}")
            return None

        d = StockDayData()
        d.code = code
        d.name = stock.get('name', '')
        d.capture_date = capture_date
        d.market_cap = float(stock.get('market_cap', 0))

        # ── 2. 일봉 데이터 (최근 20 영업일) ──
        dt_from = capture_date - timedelta(days=40)
        daily = self.db.get_daily(code, dt_from, capture_date)

        if not daily or len(daily) < 2:
            print(f"    ⚠ 일봉 부족: {code} ({len(daily) if daily else 0}건)")
            return None

        prev_days = [r for r in daily if r['dt'] < capture_date]
        if not prev_days:
            print(f"    ⚠ 전일 일봉 없음: {code}")
            return None

        prev_days.sort(key=lambda x: x['dt'])
        prev = prev_days[-1]

        d.prev_open = int(prev.get('open', 0))
        d.prev_high = int(prev.get('high', 0))
        d.prev_low = int(prev.get('low', 0))
        d.prev_close = int(prev.get('close', 0))
        d.prev_volume = int(prev.get('volume', 0))

        # ── 3. 전일 종가위치 (0~1) ──
        if d.prev_high > d.prev_low:
            d.close_position = round(
                (d.prev_close - d.prev_low) / (d.prev_high - d.prev_low), 2
            )

        # ── 4. 전일 윗꼬리 비율 ──
        body_top = max(d.prev_open, d.prev_close)
        candle_range = d.prev_high - d.prev_low
        if candle_range > 0:
            d.upper_wick_ratio = round(
                (d.prev_high - body_top) / candle_range, 2
            )

        # ── 5. 5일 평균 거래량 / 거래량비 ──
        last5 = prev_days[-5:] if len(prev_days) >= 5 else prev_days
        avg_vol = sum(int(r.get('volume', 0)) for r in last5) / len(last5)
        d.avg_volume_5d = round(avg_vol, 0)
        if avg_vol > 0 and d.prev_volume > 0:
            d.vol_ratio_5d = round(d.prev_volume / avg_vol, 2)

        # ── 6. 연속 음봉 수 ──
        count = 0
        for r in reversed(prev_days):
            if int(r.get('close', 0)) < int(r.get('open', 0)):
                count += 1
            else:
                break
        d.bearish_count = count

        # ── 7. 전일 + 당일 분봉 조회 ──
        prev_day = self._prev_business_day(capture_date)
        minutes_prev = self.db.get_minute(code, prev_day)
        minutes_today = self.db.get_minute(code, capture_date)
        minutes_all = (minutes_prev or []) + (minutes_today or [])

        # ── 8. 전일 + 당일 30틱 조회 ──
        tick30_prev = self.db.get_tick30(code, prev_day)
        tick30_today = self.db.get_tick30(code, capture_date)
        tick30_all = (tick30_prev or []) + (tick30_today or [])

        # ── 9. 당일 09:00~09:05 분봉으로 기본 지표 계산 ──
        early_minutes = [
            r for r in (minutes_today or [])
            if '09:00' <= self._tm_hhmm(r.get('tm', '')) <= '09:05'
        ]

        if early_minutes:
            d.today_open = int(early_minutes[0].get('open', 0))
            d.price_0905 = int(early_minutes[-1].get('close', 0))
            d.volume_5min = sum(int(r.get('volume', 0)) for r in early_minutes)
            d.amount_5min = sum(
                int(r.get('volume', 0)) * int(r.get('close', 0))
                for r in early_minutes
            )
        elif minutes_today:
            first = minutes_today[0]
            d.today_open = int(first.get('open', 0))
            d.price_0905 = int(first.get('close', 0))
        else:
            today_daily = [r for r in daily if r['dt'] == capture_date]
            if today_daily:
                d.today_open = int(today_daily[0].get('open', 0))
                d.price_0905 = d.today_open

        # ── 10. 갭률 ──
        if d.prev_close > 0 and d.today_open > 0:
            d.gap_pct = round(
                (d.today_open - d.prev_close) / d.prev_close * 100, 1
            )

        # ── 11. 초반 등락률 (09:05 기준) ──
        if d.today_open > 0 and d.price_0905 > 0:
            d.early_move_pct = round(
                (d.price_0905 - d.today_open) / d.today_open * 100, 1
            )

        # ── 12. 기술적 지표 계산 (분봉 DataFrame 필요) ──
        if len(minutes_all) >= 10:
            df_minute = self._to_minute_df(minutes_all)

            # 12-a. AEST
            try:
                df_aest = compute_aest(df_minute.copy())
                if 'aest' in df_aest.columns:
                    cutoff = f"{capture_date.strftime('%Y-%m-%d')} 09:05:00"
                    early_aest = df_aest[df_aest.index <= cutoff]['aest'].dropna()
                    if len(early_aest) > 0:
                        d.aest_value = round(float(early_aest.iloc[-1]), 2)
                        d.aest_bullish = d.aest_value > 0
            except Exception as e:
                print(f"    ⚠ AEST 계산 실패 {code}: {e}")

            # 12-b. SuperTrend
            try:
                df_st = compute_supertrend(df_minute.copy())
                if 'st_dir' in df_st.columns:
                    cutoff = f"{capture_date.strftime('%Y-%m-%d')} 09:05:00"
                    early_st = df_st[df_st.index <= cutoff]['st_dir'].dropna()
                    if len(early_st) > 0:
                        d.st_direction = int(early_st.iloc[-1])
                    early_stv = df_st[df_st.index <= cutoff]['supertrend'].dropna()
                    if len(early_stv) > 0:
                        d.st_value = round(float(early_stv.iloc[-1]), 2)
            except Exception as e:
                print(f"    ⚠ SuperTrend 계산 실패 {code}: {e}")

            # 12-c. JMA Trend
            try:
                df_jma = compute_jma_trend(df_minute.copy())
                if 'jma' in df_jma.columns:
                    cutoff = f"{capture_date.strftime('%Y-%m-%d')} 09:05:00"
                    early_jma = df_jma[df_jma.index <= cutoff]['jma'].dropna()
                    if len(early_jma) > 0:
                        d.jma_value = round(float(early_jma.iloc[-1]), 2)
                    early_jt = df_jma[df_jma.index <= cutoff]['jma_trend'].dropna()
                    if len(early_jt) > 0:
                        d.jma_trend = int(early_jt.iloc[-1])
            except Exception as e:
                print(f"    ⚠ JMA 계산 실패 {code}: {e}")

        # ── 13. 틱강도 계산 (분봉 + 30틱 DataFrame 모두 필요) ──
        if len(minutes_all) >= 10 and len(tick30_all) >= 10:
            try:
                df_min = self._to_minute_df(minutes_all)
                df_tick = self._to_tick30_df(tick30_all)
                df_ti = compute_tick_intensity(df_min, df_tick, tick_size=30)

                if 'tick_intensity' in df_ti.columns:
                    cutoff = f"{capture_date.strftime('%Y-%m-%d')} 09:05:00"
                    t_start = f"{capture_date.strftime('%Y-%m-%d')} 09:00:00"
                    early_ti = df_ti[
                        (df_ti.index >= t_start) & (df_ti.index <= cutoff)
                    ]

                    if len(early_ti) > 0:
                        d.tick_intensity_avg = round(
                            float(early_ti['tick_intensity'].mean()), 1
                        )

                    if 'tick_ma5' in df_ti.columns and 'tick_ma20' in df_ti.columns:
                        vals = df_ti[df_ti.index <= cutoff][['tick_ma5', 'tick_ma20']].dropna()
                        if len(vals) > 0:
                            d.tick_ma5_last = round(float(vals.iloc[-1]['tick_ma5']), 1)
                            d.tick_ma20_last = round(float(vals.iloc[-1]['tick_ma20']), 1)
                            d.tick_bearish = d.tick_ma5_last < d.tick_ma20_last
            except Exception as e:
                print(f"    ⚠ 틱강도 계산 실패 {code}: {e}")

        return d

    # ── DataFrame 변환 헬퍼 ──

    def _to_minute_df(self, rows: List[Dict]) -> pd.DataFrame:
        """분봉 dict 리스트 → pandas DataFrame (DatetimeIndex)"""
        records = []
        for r in rows:
            dt = r.get('dt')
            tm = r.get('tm', '')
            if isinstance(dt, date):
                dt_str = dt.strftime('%Y-%m-%d')
            else:
                dt_str = str(dt)
            tm_str = self._tm_to_str(tm)
            ts = f"{dt_str} {tm_str}"
            records.append({
                'datetime': ts,
                'open': int(r.get('open', 0)),
                'high': int(r.get('high', 0)),
                'low': int(r.get('low', 0)),
                'close': int(r.get('close', 0)),
                'volume': int(r.get('volume', 0)),
            })

        df = pd.DataFrame(records)
        if df.empty:
            return df
        df['datetime'] = pd.to_datetime(df['datetime'])
        df = df.sort_values('datetime').drop_duplicates(subset='datetime')
        df = df.set_index('datetime')
        return df

    def _to_tick30_df(self, rows: List[Dict]) -> pd.DataFrame:
        """30틱 dict 리스트 → pandas DataFrame (DatetimeIndex + seq)"""
        records = []
        for r in rows:
            dt = r.get('dt')
            tm = r.get('tm', '')
            if isinstance(dt, date):
                dt_str = dt.strftime('%Y-%m-%d')
            else:
                dt_str = str(dt)
            tm_str = self._tm_to_str(tm)
            ts = f"{dt_str} {tm_str}"
            records.append({
                'datetime': ts,
                'seq': int(r.get('seq', 0)),
                'open': int(r.get('open', 0)),
                'high': int(r.get('high', 0)),
                'low': int(r.get('low', 0)),
                'close': int(r.get('close', 0)),
                'volume': int(r.get('volume', 0)),
            })

        df = pd.DataFrame(records)
        if df.empty:
            return df
        df['datetime'] = pd.to_datetime(df['datetime'])
        df = df.sort_values(['datetime', 'seq'])
        df = df.set_index('datetime')
        return df
